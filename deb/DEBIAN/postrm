#!/bin/bash
# postrm script for notification-player

set -e

if [ "$1" = "purge" ]; then
    echo "Removing configuration files..."
    rm -rf /etc/notification-player
    rm -rf /var/lib/notification-player
    rm -rf /var/log/notification-player
    
    if id -u notification-player >/dev/null 2>&1; then
        userdel notification-player
        echo "Removed notification-player user"
    fi
fi

exit 0